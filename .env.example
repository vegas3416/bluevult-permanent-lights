# Copy to .env and fill in. Do not commit .env.

VITE_FORMSUBMIT_EMAIL=info@bluevultlighting.com
# Optional: paste the id from FormSubmit’s activation email to use the hashed endpoint (recommended).
# VITE_FORMSUBMIT_FORM_ID=

# Supabase (password reset on the marketing site)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Search Console → property → Settings → Ownership verification → HTML tag (content=… only)
VITE_GOOGLE_SITE_VERIFICATION=

# Gallery / social (optional — defaults are set in src/lib/seo/siteConfig.ts)
# VITE_GOOGLE_BUSINESS_URL=
# VITE_FACEBOOK_PAGE_URL=
# VITE_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...

# Facebook → website gallery sync (store these in Supabase → Edge Functions → Secrets, not in .env)
# GALLERY_SYNC_SECRET=            # random string; same value in POST header x-gallery-sync-secret
# FACEBOOK_PAGE_ACCESS_TOKEN=    # long-lived Page token from Graph API
# FACEBOOK_PAGE_ID=1061760347010857   # optional; defaults to BlueVult Graph Page id in siteConfig

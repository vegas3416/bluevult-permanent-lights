# Copy this file to .env and fill in your values to enable email/SMS testing

# Email receiver for FormSubmit (free). Example: you@yourdomain.com
VITE_FORMSUBMIT_EMAIL=you@yourdomain.com

# Optional: email-to-SMS gateway address for your phone (carrier-dependent)
# Example (Verizon): 15124611926@vtext.com
# Replace with your 10-digit number and carrier gateway.
VITE_SMS_GATEWAY=15124611926@vtext.com

# Optional: Formspree (alternative to FormSubmit). Example: yourFormId
VITE_FORMSPREE_ID=

# NOTE: After creating .env, restart the dev server (npm run dev)
